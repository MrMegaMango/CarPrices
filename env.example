# Database
DATABASE_URL="postgresql://username:password@localhost:5432/carprices?schema=public"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Feedback Email (required for confirmation emails)
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
# Optional override for From header (defaults to CarDeals <GMAIL_USER>)
FEEDBACK_EMAIL_FROM=""
# Admin recipients for incoming feedback notifications
# Use one or both. FEEDBACK_ADMIN_EMAILS supports comma/space/semicolon-separated values.
FEEDBACK_ADMIN_EMAIL=""
FEEDBACK_ADMIN_EMAILS=""
